              "name": "respuesta",
              "value": "={{ $json.output.replace(/\\[Used tools?:[^\\]]{0,800}\\]/gi, '').replace(/\\[\\{[^}]{0,800}\\}\\]/gi, '').replace(/Tool:\\s*\\S[^\\n]*/g, '').replace(/Input:\\s*\\{[^}]{0,400}\\}/g, '').replace(/Result:\\s*\\[[^\\]]{0,800}\\]/g, '').replace(/\\*?\\s*https?:\\/\\/\\S+\\.(?:jpg|jpeg|png|gif|mp4|mov|webm)[^\\n]*/gi, '').replace(/\\n{3,}/g, '\\n\\n').trim() }}",
