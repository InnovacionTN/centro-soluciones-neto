              "value": "={{ $json.output.length > 120 ? $json.output.replace(/[\\n\\r]+/g, ' ').substring(0, 200).trim() + '…' : '' }}",
              "type": "string"
            },
            {
              "id": "csn-b004",
              "name": "multimedia_url",
              "value": "={{ (() => {\n  const full = $json.output\n    .match(/https?:\\/\\/\\S+/gi)\n    ?.filter(u => /\\.(jpg|jpeg|png|gif|mp4|mov|webm)/i.test(u))\n    ?.map(u => u.replace(/[*•,\\s]+$/, '')) || [];\n  const all = [...new Set(full)];\n  return all.length ? all.join(',') : null;\n})() }}",
              "type": "string"
            }
          ]
        },
