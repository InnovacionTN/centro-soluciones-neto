# ─── Modelo (Google Gemini) ────────────────────────────────────────────────
# El provider @ai-sdk/google lee GOOGLE_GENERATIVE_AI_API_KEY.
# En CSN el secreto se llama GEMINI_API_KEY; en el deploy lo mapeamos a esta var.
GOOGLE_GENERATIVE_AI_API_KEY=
DANY_MODEL=gemini-2.5-flash

# ─── Backend CSN (las tools pegan aquí con X-Dany-Token) ────────────────────
CSN_API_URL=https://csn-api-prod-312707215871.us-central1.run.app
DANY_SYSTEM_TOKEN=
# Secreto de entrada al webhook (el backend lo manda en X-Dany-Webhook-Secret).
# Déjalo vacío para la primera prueba; actívalo en producción.
DANY_WEBHOOK_SECRET=

# ─── Servidor de multimedia (Dany) ─────────────────────────────────────────
DANY_MEDIA_BASE_URL=https://dany.netopower123.com
DANY_MEDIA_API_KEY=

# ─── Persistencia (Neon / Postgres de CSN) ─────────────────────────────────
# Memoria de chat por sesion_id + KB de hardware. Se llena en Fase 2/3.
DATABASE_URL=

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
