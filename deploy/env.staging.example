# ── Variables de entorno para Cloud Run STAGING ──────────────────────────────
# Copiar como secretos en GCP Secret Manager o configurar directo en Cloud Run
# NO commitear valores reales — este archivo es solo de referencia

ENVIRONMENT=staging
DATABASE_URL=postgresql://user:pass@host/csn_staging
SECRET_KEY=staging-secret-key-minimo-32-caracteres-aleatorios
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

GEMINI_API_KEY=AIza...
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#centro-soluciones-staging

DANY_WEBHOOK_URL=https://webhook.soyneto.com/webhook/dany-csn-staging

STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=csn-uploads-staging
MAX_UPLOAD_SIZE_MB=10

# CORS: solo necesario para clientes externos (Javier/WhatsApp, Postman, etc.)
# Firebase Hosting reescribe /api/** internamente — no requiere CORS del frontend
CORS_ORIGINS=http://localhost:4200,https://csn-staging.web.app
