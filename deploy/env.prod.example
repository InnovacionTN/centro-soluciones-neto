# ── Variables de entorno para Cloud Run PRODUCCIÓN ───────────────────────────
# Gestionar EXCLUSIVAMENTE via GCP Secret Manager
# NO commitear valores reales

ENVIRONMENT=production
DATABASE_URL=postgresql://user:pass@host/csn_prod
SECRET_KEY=prod-secret-key-minimo-32-caracteres-completamente-aleatorios
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

GEMINI_API_KEY=AIza...
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#centro-soluciones-neto

DANY_WEBHOOK_URL=https://webhook.soyneto.com/webhook/dany-csn

STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=csn-uploads-prod
MAX_UPLOAD_SIZE_MB=10

CORS_ORIGINS=https://csn-prod.web.app,https://soluciones.soyneto.com
